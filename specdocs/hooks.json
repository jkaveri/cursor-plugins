{
  "description": "Remind to update docs/specs/ or docs/decisions/ after Write or Edit (Claude Code PostToolUse).",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/warn-missing-doc-updates/warn.sh"
          }
        ]
      }
    ]
  }
}
